#include <bits/stdc++.h>
#define ll long long 
ll mod=1000000007;
using namespace std;

int main() {
    int n; cin>>n;
    ll cord[n], speed[n];
    for(int i=0; i<n; i++){
        cin>>cord[i];
    }
    for(int i=0; i<n; i++){
        cin>>speed[i];
    }

    long double st=0 , end=1000000000,mid;
    while(end - st > 1e-6){
        int kh=0;
        mid=(st+end)/2;
        long double prev1,prev2,curr1=0,curr2=0;
        prev1=cord[0]-mid*speed[0];
        prev2=cord[0]+mid*speed[0];
        for(int i=1; i<n; i++){
            
              curr1=cord[i]-mid*speed[i];
              curr2=cord[i]+mid*speed[i];
              prev1=max(prev1,curr1);
              prev2=min(prev2,curr2);
        if(prev2>=prev1){
           continue;
        }
            else{
                kh=1; break;
            }
        }
        if(kh==0){
            end=mid;
        }
        else st=mid+0.000001;


    }
    cout<<fixed<<setprecision(9)<<st;
}
