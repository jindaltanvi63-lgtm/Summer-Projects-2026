#include <bits/stdc++.h>
#define ll long long
ll mod=1000000007;
using namespace std;

int main() {
	ll n,k; cin>>n>>k;
    ll ar[n];
    for(int i=0; i<n; i++){
        cin>>ar[i];
    }
    if(n==1) {cout<<ar[0]; return 0;}
    ll st=0, end=200000;
  while(st<end){
    int kh=0;
    ll mid=(st+end+1)/2;
    int zer[n];
    for(int i=0; i<n; i++){
        if(ar[i]>=mid) zer[i]=1;
        else zer[i]=-1;
    }
    ll minm=0;
    ll prf[n];
    prf[0]=zer[0];
    for(int i=1; i<n; i++){
        prf[i]=prf[i-1]+zer[i];
         
       if(i>=k) minm=min(minm,prf[i-k]);
       if(i>=k-1){
        if(prf[i]-minm>0){
            st=mid;kh=1;  break;
        } 
       }
    }
    if(kh==0) end=mid-1;
  }
  cout<<st<<endl;

// odd 
}
